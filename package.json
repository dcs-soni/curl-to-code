{
  "name": "curl-to-code",
  "version": "1.1.0",
  "description": "CLI tool that converts cURL commands / API URLs into TypeScript interfaces, Zod schemas, and type-safe fetch clients.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "curl-to-code": "./dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "npx tsx --test \"test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "curl",
    "typescript",
    "zod",
    "code-generation",
    "api",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "gradient-string": "^3.0.0",
    "ink": "^6.8.0",
    "json-to-ts": "^2.1.0",
    "json-to-zod": "^1.1.2",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "yargs": "^18.0.0",
    "yargs-parser": "^22.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/yargs": "^17.0.35",
    "@types/yargs-parser": "^21.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
